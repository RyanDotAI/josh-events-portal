// ============================================================
// PAGE: MyCertifications
// Displays the logged-in contact's certifications from CRM.
// Requires an Event_Certifications module in CRM (or equivalent
// field structure — see note below).
//
// NOTE: When the CRM certification module is finalized (post-LearnWorlds
// integration), update the zoho.crm.searchRecords call to match the
// actual module API name and field names. The placeholder "Certifications"
// module name and field names below will need to be updated.
// ============================================================


// ── DELUGE SCRIPT (paste into page Script tab) ───────────────

PORTAL_BASE = "YOUR_PORTAL_BASE_URL";

p_session  = input.session;
sess_check = fn_validateSession(p_session);

if(sess_check.get("valid").toString() != "true")
{
	nav_html     = "";
	page_content = "<script>window.location.href='" + PORTAL_BASE + "/#Page:Login?error=session_expired';</script>";
}
else
{
	contact_id = sess_check.get("contact_id").toString();
	contact    = fn_getContactProfile(contact_id);
	full_name  = contact.get("full_name").toString();

	nav_html = "<header class='portal-header'>"
	         + "<span class='brand'>Josh.ai Event Portal</span>"
	         + "<span class='user-chip'>" + full_name + "</span>"
	         + "</header>"
	         + "<nav class='portal-nav'>"
	         + "<a href='" + PORTAL_BASE + "/#Page:Events?session=" + p_session + "'>Events</a>"
	         + "<a href='" + PORTAL_BASE + "/#Page:MyRegistrations?session=" + p_session + "'>My Registrations</a>"
	         + "<a href='" + PORTAL_BASE + "/#Page:MyCertifications?session=" + p_session + "' class='active'>Certifications</a>"
	         + "<a href='" + PORTAL_BASE + "/#Page:Login' style='float:right;'>Sign Out</a>"
	         + "</nav>";

	// ── Fetch certifications from CRM ────────────────────────────────────────
	// TODO: Update "Certifications" below to your actual CRM module API name
	// TODO: Update field names to match your Certifications module schema
	certs = zoho.crm.searchRecords("Certifications",
		"(Contact:equals:" + contact_id + ")", 1, 200, null, null);

	today_str = zoho.currentdate.toString("yyyy-MM-dd");

	if(certs == null || certs.size() == 0)
	{
		certs_html = "<div class='empty-state'>"
		           + "<div class='empty-icon'>🎓</div>"
		           + "<h3>No certifications on file</h3>"
		           + "<p>Certifications will appear here after completing a Josh.ai training program.</p>"
		           + "<p style='margin-top:12px;'><a href='" + PORTAL_BASE + "/#Page:Events?session=" + p_session + "' class='cta-link'>View upcoming trainings →</a></p>"
		           + "</div>";
	}
	else
	{
		certs_html = "";

		for each cert in certs
		{
			// TODO: Update field names below to match your CRM Certifications module
			cert_name    = ifnull(cert.get("Certification_Name"), "").toString();
			cert_level   = ifnull(cert.get("Level"), "").toString();
			cert_type    = ifnull(cert.get("Certification_Type"), "").toString();
			issued_date  = ifnull(cert.get("Issue_Date"), "").toString();
			expiry_date  = ifnull(cert.get("Expiry_Date"), "").toString();
			cert_id      = ifnull(cert.get("Certificate_ID"), "").toString();

			// Status — active or expired
			status_html  = "";
			status_class = "status-active";
			status_label = "Active";
			if(expiry_date != "" && expiry_date != "null" && expiry_date < today_str)
			{
				status_class = "status-expired";
				status_label = "Expired";
			}

			expiry_html = "";
			if(expiry_date != "" && expiry_date != "null")
			{
				if(expiry_date < today_str)
				{
					expiry_html = "<span class='expiry expired'>Expired " + expiry_date + "</span>";
				}
				else
				{
					expiry_html = "<span class='expiry'>Expires " + expiry_date + "</span>";
				}
			}

			level_html = "";
			if(cert_level != "")
			{
				level_html = "<span class='level-badge'>Level " + cert_level + "</span>";
			}

			id_html = "";
			if(cert_id != "")
			{
				id_html = "<div class='cert-id'>Certificate ID: " + cert_id + "</div>";
			}

			certs_html = certs_html
			           + "<div class='cert-card " + status_class + "'>"
			           + "<div class='cert-header'>"
			           + "<span class='status-dot'></span>"
			           + "<span class='status-text'>" + status_label + "</span>"
			           + level_html
			           + "</div>"
			           + "<h3 class='cert-name'>" + cert_name + "</h3>"
			           + "<div class='cert-meta'>"
			           + "<span class='cert-type'>" + cert_type + "</span>"
			           + "<span class='cert-sep'>·</span>"
			           + "<span>Issued " + issued_date + "</span>"
			           + expiry_html
			           + "</div>"
			           + id_html
			           + "</div>";
		}
	}

	page_content = certs_html;
}


// ── HTML COMPONENT ───────────────────────────────────────────

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background: #f0f2f5; color: #212121; }
.portal-header { background: #0d1b2a; color: white; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; }
.brand { font-size: 18px; font-weight: 700; }
.user-chip { background: rgba(255,255,255,0.12); padding: 4px 12px; border-radius: 20px; font-size: 13px; }
.portal-nav { background: #162032; padding: 0 20px; overflow: hidden; }
.portal-nav a { color: rgba(255,255,255,0.65); text-decoration: none; display: inline-block; padding: 12px 16px; font-size: 14px; font-weight: 500; }
.portal-nav a:hover { color: white; }
.portal-nav a.active { color: white; border-bottom: 2px solid #60a5fa; }
.main { max-width: 860px; margin: 0 auto; padding: 28px 20px; }
.cert-card { background: white; border-radius: 10px; padding: 22px 24px; margin-bottom: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); border-left: 4px solid #22c55e; }
.cert-card.status-expired { border-left-color: #d1d5db; opacity: 0.8; }
.cert-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.status-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; }
.status-expired .status-dot { background: #9ca3af; }
.status-text { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #22c55e; }
.status-expired .status-text { color: #9ca3af; }
.level-badge { background: #ede9fe; color: #5b21b6; padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
.cert-name { font-size: 18px; font-weight: 700; color: #0d1b2a; margin-bottom: 8px; }
.cert-meta { display: flex; gap: 10px; align-items: center; font-size: 13px; color: #666; flex-wrap: wrap; }
.cert-type { font-weight: 600; color: #374151; }
.cert-sep { color: #d1d5db; }
.expiry { font-size: 12px; color: #666; }
.expiry.expired { color: #dc2626; font-weight: 600; }
.cert-id { font-size: 12px; color: #9ca3af; margin-top: 10px; font-family: monospace; }
.empty-state { text-align: center; padding: 60px 20px; color: #9ca3af; }
.empty-icon { font-size: 48px; margin-bottom: 14px; }
.empty-state h3 { font-size: 18px; font-weight: 600; color: #6b7280; margin-bottom: 10px; }
.empty-state p { font-size: 14px; line-height: 1.6; }
.cta-link { color: #0069c0; text-decoration: none; font-weight: 600; }
</style>

{%nav_html%}
<div class="main">
  <h1 style="font-size:24px;font-weight:700;color:#0d1b2a;margin-bottom:6px;">My Certifications</h1>
  <p style="font-size:14px;color:#666;margin-bottom:24px;">Certifications are automatically updated when you complete a Josh.ai training program.</p>
  {%page_content%}
</div>
